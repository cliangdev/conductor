# PostgreSQL
POSTGRES_DB=conductor
POSTGRES_USER=conductor
POSTGRES_PASSWORD=conductor

# JWT — change this for any non-local environment
JWT_SECRET=local-dev-jwt-secret-change-in-production

# Local auth — shared password for all local users (not a real secret)
LOCAL_DEV_PASSWORD=conductor

# Local file storage path (relative to repo root)
# LOCAL_STORAGE_PATH=./local-uploads

# Backend base URL for generating local file URLs
# SERVER_BASE_URL=http://localhost:8080
